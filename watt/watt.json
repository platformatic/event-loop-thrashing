{
  "$schema": "https://schemas.platformatic.dev/@platformatic/runtime/3.33.0.json",
  "watch": true,
  "autoload": {
    "path": "web",
    "exclude": [
      "docs"
    ]
  },
  "logger": {
    "level": "{PLT_SERVER_LOGGER_LEVEL}"
  },
  "server": {
    "hostname": "{PLT_SERVER_HOSTNAME}",
    "port": "{PORT}"
  },
  "entrypoint": "composer",
  "workers": "{WORKERS}",
  "managementApi": false,
  "health": {
    "enabled": "{HEALTH_ENABLED}",
    "interval": "{HEALTH_INTERVAL}",
    "maxELU": "{HEALTH_MAX_ELU}",
    "maxUnhealthyChecks": "{HEALTH_MAX_UNHEALTHY_CHECKS}"
  }
}
